# Database (Docker: db:5432, 로컬: localhost:5433)
DATABASE_URL="postgresql://wpcomp:wpcomp_dev@localhost:5433/wpcomp"
POSTGRES_PASSWORD="wpcomp_dev"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Encryption key for WP Application Passwords (AES-256-GCM)
ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# Cron sync secret
CRON_SECRET="generate-with-openssl-rand-hex-16"
